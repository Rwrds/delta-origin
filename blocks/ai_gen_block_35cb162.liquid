{% doc %}
  @prompt
    Product tab information
    
    tabing view with html content and option to conect with metafield
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-tabs-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-product-tabs__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.container_padding }}px;
  }

  .ai-product-tabs__tab-list-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.tab_gap }}px;
    border-bottom: {{ block.settings.tab_border_thickness }}px solid {{ block.settings.tab_border_color }};
    margin-bottom: {{ block.settings.content_spacing }}px;
    flex-wrap: wrap;
  }

  .ai-product-tabs__tab-button-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: {{ block.settings.tab_padding }}px;
    cursor: pointer;
    font-size: {{ block.settings.tab_font_size }}px;
    color: {{ block.settings.tab_text_color }};
    position: relative;
    transition: color 0.3s ease;
  }

  .ai-product-tabs__tab-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_active_color }};
  }

  .ai-product-tabs__tab-button-{{ ai_gen_id }}.active {
    color: {{ block.settings.tab_active_color }};
  }

  .ai-product-tabs__tab-button-{{ ai_gen_id }}.active::after {
    content: '';
    position: absolute;
    bottom: calc(-1 * {{ block.settings.tab_border_thickness }}px);
    left: 0;
    right: 0;
    height: {{ block.settings.active_indicator_height }}px;
    background-color: {{ block.settings.tab_active_color }};
  }

  .ai-product-tabs__content-{{ ai_gen_id }} {
    display: none;
  }

  .ai-product-tabs__content-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-product-tabs__content-{{ ai_gen_id }} p {
    margin: 0 0 1em 0;
  }

  .ai-product-tabs__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-product-tabs__content-{{ ai_gen_id }} h1,
  .ai-product-tabs__content-{{ ai_gen_id }} h2,
  .ai-product-tabs__content-{{ ai_gen_id }} h3,
  .ai-product-tabs__content-{{ ai_gen_id }} h4,
  .ai-product-tabs__content-{{ ai_gen_id }} h5,
  .ai-product-tabs__content-{{ ai_gen_id }} h6 {
    margin: 0 0 0.5em 0;
  }

  .ai-product-tabs__content-{{ ai_gen_id }} ul,
  .ai-product-tabs__content-{{ ai_gen_id }} ol {
    margin: 0 0 1em 0;
    padding-left: 1.5em;
  }

  .ai-product-tabs__empty-state-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: #999;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-product-tabs__tab-list-{{ ai_gen_id }} {
      gap: {{ block.settings.tab_gap | times: 0.5 }}px;
    }

    .ai-product-tabs__tab-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.tab_font_size | times: 0.9 }}px;
      padding: {{ block.settings.tab_padding | times: 0.8 }}px;
    }

    .ai-product-tabs__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<product-tabs-{{ ai_gen_id }} class="ai-product-tabs-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-tabs__container-{{ ai_gen_id }}">
    <div class="ai-product-tabs__tab-list-{{ ai_gen_id }}" role="tablist">
      {% if block.settings.tab_1_enabled %}
        <button
          class="ai-product-tabs__tab-button-{{ ai_gen_id }} active"
          role="tab"
          aria-selected="true"
          aria-controls="ai-product-tabs-panel-1-{{ ai_gen_id }}"
          data-tab="1"
        >
          {{ block.settings.tab_1_title }}
        </button>
      {% endif %}

      {% if block.settings.tab_2_enabled %}
        <button
          class="ai-product-tabs__tab-button-{{ ai_gen_id }}"
          role="tab"
          aria-selected="false"
          aria-controls="ai-product-tabs-panel-2-{{ ai_gen_id }}"
          data-tab="2"
