          data-tab="4"
        >
          {{ block.settings.tab_4_title }}
        </button>
      {% endif %}
    </div>

    {% if block.settings.tab_1_enabled %}
      <div
        id="ai-product-tabs-panel-1-{{ ai_gen_id }}"
        class="ai-product-tabs__content-{{ ai_gen_id }} active"
        role="tabpanel"
        data-panel="1"
      >
        {% if block.settings.tab_1_metafield != blank %}
          {% assign metafield_parts = block.settings.tab_1_metafield | split: '.' %}
          {% if metafield_parts.size == 2 %}
            {% assign namespace = metafield_parts[0] %}
            {% assign key = metafield_parts[1] %}
            {% if product.metafields[namespace][key] != blank %}
              {{ product.metafields[namespace][key] }}
            {% elsif block.settings.tab_1_content != blank %}
              {{ block.settings.tab_1_content }}
            {% else %}
              <div class="ai-product-tabs__empty-state-{{ ai_gen_id }}">
                Add content or connect a metafield
              </div>
            {% endif %}
          {% elsif block.settings.tab_1_content != blank %}
            {{ block.settings.tab_1_content }}
          {% else %}
            <div class="ai-product-tabs__empty-state-{{ ai_gen_id }}">
              Add content or connect a metafield
            </div>
          {% endif %}
        {% elsif block.settings.tab_1_content != blank %}
          {{ block.settings.tab_1_content }}
        {% else %}
