            "tab_3_enabled": true,
            "tab_3_title": "FAQ",
            "tab_3_content": "<style>\n  .question p,\n  .page-question p {\n    margin: 0;\n  }\n\n  .question {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    font-weight: 800;\n    padding: 1rem 0;\n  }\n\n  .answer {\n    display: none;\n    padding: 0 0 1rem 0.5rem;\n  }\n\n  #requestForm {\n    margin: 20px 30px;\n  }\n\n  #requestForm div {\n    display: flex;\n    justify-content: space-evenly;\n  }\n\n  #requestForm div input {\n    border-radius: 25px;\n    width: 75%;\n    padding: 10px;\n    border: 1px solid;\n  }\n\n  #requestForm div button {\n    border-radius: 25px;\n    border: 1px solid;\n    width: 10%;\n  }\n\n  @media screen and (max-width: 768px) {\n    #requestForm div button {\n      width: 20%;\n    }\n  }\n\n  .loader {\n    border: 5px solid #f3f3f3;\n    -webkit-animation: spin 1s linear infinite;\n    animation: spin 1s linear infinite;\n    border-top: 5px solid #555;\n    border-radius: 50%;\n    width: 25px;\n    height: 25px;\n  }\n\n  @keyframes spin {\n    0% {\n      transform: rotate(0deg);\n    }\n\n    100% {\n      transform: rotate(360deg);\n    }\n  }\n\n  .text-center {\n    text-align: center;\n  }\n\n  #faqQuesEmbed .toggleSymbol {\n    color: #ffb718;\n    font-size: 2.3rem;\n    line-height: 0;\n  }\n</style>\n<script>\n  var faqEndpoint = '/api/faq';\n  var questionRequestEndpoint = '/api/question_request';\n  var FAQ_HOST = '/apps/faq-host';\n  var shop = window.Shopify.shop || window.location.href.split('//')[1].split('/')[0];\n  var product_id = window.ShopifyAnalytics?.meta?.page?.resourceId;\n\n  if (product_id !== undefined) {\n    fetch(FAQ_HOST + faqEndpoint + '?shop=' + shop + '&product_id=' + product_id, {\n      method: \"GET\",\n      headers: {\n        'Content-Type': 'application/json'\n      }\n    })\n      .then(function (response) {\n        if (response.status === 200) {\n          response.json().then(function (data) {\n            if (data.response.status == 200) {\n              const widgetData = data.response.data.widget;\n              if (widgetData) {\n                if (!widgetData) return console.warn(\"Widget data is missing or invalid.\");\n              }\n\n              if (data.response.data.faq_type === \"group_view\") {\n                groupQueAns = data.response.data.product_faq;\n                pageGroupView(groupQueAns, widgetData)\n              } else {\n                faqQuesAns = data.response.data.product_faq\n                pageListView(faqQuesAns, widgetData)\n                addFaqJsonLdToHead(faqQuesAns, data.response.data.faq_schema);\n              }\n              isAskSection(data.response.data.setting, widgetData)\n              const questionElements = document.querySelectorAll('.question p');\n              questionElements.forEach((element) => {\n                element.style.fontSize = widgetData.qTextSize;\n                element.style.fontWeight = widgetData.qTextWeight;\n              });\n            }\n          });\n        }\n      })\n      .catch(function (err) {\n        console.log(err)\n      });\n  }\n\n  // Group View\n  function pageGroupView(groupQueAns, widgetData) {\n\n    var groupview = \"\";\n    groupQueAns.forEach((group, i) => {\n      groupview += `<p><b>${group.name}</b></p>`;\n      group.questions.forEach((que, idx) => {\n        groupview += `\n        <hr style=\"margin: 0;\">\n        <div id=\"${i}-question-${idx}\" style=\"cursor:pointer;\">\n          <div class=\"question\">\n            <p> ${que.question}</p>\n            <p class=\"toggleSymbol\">+</p>\n          </div>\n          <div class=\"answer\">\n            ${que.answer}\n          </div>\n        </div>`;\n      });\n    });\n\n    document.getElementById(\"faqQuesEmbed\").innerHTML = groupview;\n    var qsec = document.querySelectorAll(\".question:not(.demo-question)\");\n\n    for (var fIndex = 0; fIndex < qsec.length; fIndex++) {\n      qsec[fIndex].addEventListener(\"click\", function () {\n        var answer = this.nextElementSibling;\n        var symbol = this.querySelector(\".toggleSymbol\");\n        if (answer.style.display === \"block\") {\n          answer.style.display = \"none\";\n          symbol.innerHTML = \"+\";\n        } else {\n          answer.style.display = \"block\";\n          symbol.innerHTML = \"-\";\n        }\n      });\n    }\n  }\n\n  // List View\n  function pageListView(faqQuesAns, widgetData) {\n    var fsec = \"\";\n    faqQuesAns.map((f, i) => {\n      fsec += `<hr style=\"margin: 0;\"><div id=\"${i}\" style=\"cursor:pointer;\">\n        <div class=\"question\">\n          <p> ${f.question} </p>\n          <p class=\"toggleSymbol\">+</p>\n        </div>\n        <div class=\"answer\">${f.answer}</div>\n      </div>`;\n    })\n    fsec += `<hr style=\"margin: 0;\">`\n    document.getElementById(\"faqQuesEmbed\").innerHTML = fsec;\n    var qsec = document.getElementsByClassName(\"question\");\n    for (var fIndex = 0; fIndex < faqQuesAns.length; fIndex++) {\n      qsec[fIndex].addEventListener(\"click\", function () {\n        var answer = this.nextElementSibling;\n        var symbol = this.querySelector(\".toggleSymbol\");\n        if (answer.style.display === \"block\") {\n          answer.style.display = \"none\";\n          symbol.innerHTML = \"+\";\n        } else {\n          answer.style.display = \"block\";\n          symbol.innerHTML = \"-\";\n        }\n      });\n    }\n  }\n\n  function addFaqJsonLdToHead(faqs, faq_schema) {\n    if (!faq_schema || faqs.length === 0) {\n      return; // Do not add the script if faq_schema is false or there are no FAQs\n    }\n    // Create a new <script> element\n    const scriptElement = document.createElement('script');\n    scriptElement.type = 'application/ld+json';\n\n    // Construct JSON-LD content dynamically\n    const jsonLdContent = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"FAQPage\",\n      \"mainEntity\": faqs.map(faq => ({\n        \"@type\": \"Question\",\n        \"name\": faq.question,\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": faq.answer\n        }\n      }))\n    };\n\n    // Set the JSON-LD content as the innerHTML of the script element\n    scriptElement.innerHTML = JSON.stringify(jsonLdContent);\n\n    // Append the script element to the <head> tag\n    document.head.appendChild(scriptElement);\n  }\n\n  function isAskSection(setting, widgetData) {\n    var askQuestion = document.getElementById('askQuestion');\n    var askQuestionText = document.getElementById('askQuestionText');\n    var askQuestionFieldText = document.getElementById('askQuestionFieldText');\n    var submitButton = document.getElementById('submitButton');\n\n    if (askQuestionText) {\n      const firstParagraph = askQuestionText.querySelector('p:first-child');\n      if (firstParagraph) {\n        firstParagraph.textContent = widgetData.askQuestiontext;\n      }\n    }\n\n    if (askQuestionFieldText) {\n      askQuestionFieldText.textContent = widgetData.askQuestionInputText;\n    }\n\n    if (submitButton) {\n      submitButton.textContent = widgetData.askQuestionButtonText;\n    }\n\n    if (setting === true) {\n      askQuestion.style.display = \"block\"\n    } else {\n      if (askQuestion) {\n        while (askQuestion.firstChild) {\n          askQuestion.removeChild(askQuestion.firstChild);\n        }\n      }\n    }\n  }\n\n  function request(value) {\n    var submitButton = document.getElementById('submitButton');\n    submitButton.disabled = !submitButton.disabled;\n    var loaderContainer = document.createElement('div');\n    loaderContainer.className = \"loader-container\";\n    var loader = document.createElement('div');\n    loader.className = \"loader\";\n    loaderContainer.appendChild(loader);\n    submitButton.parentNode.insertBefore(loaderContainer, submitButton.nextSibling);\n    var customerId = ShopifyAnalytics.meta.page.customerId;\n    let formData = {\n      question_request: {\n        question: value,\n        customer_id: customerId,\n        customer_name: customer_details.name,\n        customer_email: customer_details.email,\n        product_handle: customer_details.product_handle,\n        store_logo: customer_details.logo,\n        product_id: product_id,\n        product_name: customer_details.product_name\n      }\n    }\n    fetch(FAQ_HOST + questionRequestEndpoint + '?shop=' + shop, {\n      method: \"POST\",\n      headers: {\n        'Content-Type': 'application/json'\n      },\n      body: JSON.stringify(formData),\n    })\n      .then(function (response) {\n        if (response.status === 200) {\n          response.json().then(function (data) {\n            if (data.response.status === 200) {\n              let responseData = data.response.message\n              afterSubmit(responseData)\n            } else {\n              let responseData = data.response.message.messages.toString();\n              afterSubmit(responseData)\n            }\n          });\n        } else {\n          let responseData = \"Question request is not submitted, please try again!\"\n          afterSubmit(responseData)\n        }\n      })\n      .catch(function (err) {\n        console.log(err)\n      });\n  }\n\n  function afterSubmit(response) {\n    var massage = document.getElementById('massage');\n    var responseData = response\n    massage.innerHTML = responseData\n    var loaderContainer = document.querySelector('.loader-container');\n    if (loaderContainer) {\n      loaderContainer.parentNode.removeChild(loaderContainer);\n    }\n    var inputField = document.getElementById('inputField');\n    inputField.value = \"\";\n    setTimeout(function () {\n      massage.innerHTML = \"\";\n      var submitButton = document.getElementById('submitButton');\n      submitButton.disabled = !submitButton.disabled\n    }, 5000);\n  }\n\n  var demoques = document.getElementsByClassName(\"demo-question\");\n  for (var fIndex = 0; fIndex < demoques.length; fIndex++) {\n    demoques[fIndex].addEventListener(\"click\", function () {\n      var answer = this.nextElementSibling;\n      var symbol = this.querySelector(\".toggleSymbol\");\n\n      if (answer.style.display === \"block\" || answer.style.display === \"\") {\n        answer.style.display = \"none\";\n        symbol.innerHTML = \"+\";\n      } else {\n        answer.style.display = \"block\";\n        symbol.innerHTML = \"-\";\n      }\n    });\n  }\n</script>\n<div id=\"faqQuesEmbed\"></div>",
